# ============================================
# TeleFeed Clone — Configuration File
# ============================================
# Copy this file to .env and fill in your values
#
# HOW TO GET THESE:
#   TG_API_ID & TG_API_HASH -> https://my.telegram.org
#     1. Log in with your phone number
#     2. Go to "API development tools"
#     3. Create an app (any name/url is fine)
#     4. Copy "App api_id" and "App api_hash"
#
#   TG_BOT_TOKEN -> Open Telegram, search @BotFather
#     1. Send /newbot
#     2. Choose name and username
#     3. Copy the token it gives you
#
#   OPENAI_API_KEY -> https://platform.openai.com/api-keys
#     (Optional - only needed for /translate feature)
# ============================================

TG_API_ID=12345678
TG_API_HASH=your_api_hash_here
TG_BOT_TOKEN=your_bot_token_here
OPENAI_API_KEY=sk-your-openai-key-here
